# ============================================================
# ATLASOPS - Root environment (docker compose)
# Copy to .env and adjust as needed:  cp .env.example .env
# ============================================================

# --- Postgres ---
POSTGRES_USER=atlasops
POSTGRES_PASSWORD=change-me-local-dev-password
POSTGRES_DB=atlasops
POSTGRES_PORT=5432

# --- Backend ---
BACKEND_PORT=8000
JWT_SECRET_KEY=change-me-in-production-please-32chars-min
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:3000
SEED_ON_STARTUP=true
ENVIRONMENT=development

# --- AI Layer (optional). If unset, the AI Advisor uses a deterministic local engine. ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Frontend ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
